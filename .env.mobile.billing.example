# Copy these values into Netlify Environment Variables for the mobile billing setup.
# Replace every placeholder before using in production.

# RevenueCat public SDK keys
REVENUECAT_IOS_API_KEY=YOUR_REVENUECAT_IOS_PUBLIC_SDK_KEY
REVENUECAT_ANDROID_API_KEY=YOUR_REVENUECAT_ANDROID_PUBLIC_SDK_KEY

# RevenueCat server-side secret
REVENUECAT_SECRET_KEY=YOUR_REVENUECAT_SERVER_SECRET

# RevenueCat project configuration
REVENUECAT_PROJECT_ID=YOUR_REVENUECAT_PROJECT_ID
REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium
REVENUECAT_OFFERING_ID=default

# Product mapping used by the backend to translate store purchases into app plans
REVENUECAT_PRODUCTS_PREMIUM_MONTHLY=com.mystodev.rbtgenius.premium.monthly,premium:monthly
REVENUECAT_PRODUCTS_PREMIUM_YEARLY=com.mystodev.rbtgenius.premium.yearly,premium:yearly

# Existing Stripe web billing
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_PREMIUM_MONTHLY=YOUR_STRIPE_MONTHLY_PRICE_ID
STRIPE_PRICE_PREMIUM_YEARLY=YOUR_STRIPE_YEARLY_PRICE_ID
